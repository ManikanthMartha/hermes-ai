# ────────────────────────────────────────────────────────────
# LLM Providers
# ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
CREDENTIAL_ENCRYPTION_KEY=replace-with-32-plus-random-characters
BETTER_AUTH_SECRET=replace-with-32-plus-random-characters

# ────────────────────────────────────────────────────────────
# Infrastructure (cloud-first — same connection shape dev & prod)
# ────────────────────────────────────────────────────────────
# Neon PostgreSQL (dev branch). Includes pgvector extension.
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/hermes?sslmode=require

# Upstash Redis. TLS (rediss://).
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379
# Upstash HTTP (for edge/Next.js). Optional if only ioredis is used.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ────────────────────────────────────────────────────────────
# MCP Integrations (populated in Phase 3)
# ────────────────────────────────────────────────────────────
# Google Cloud project -> enable Gmail API + Calendar API -> Web OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=primary
CALENDAR_LOOKAHEAD_DAYS=14
CALENDAR_INCLUDE_PRIVATE=false
CALENDAR_POLL_ENABLED=false
CALENDAR_POLL_INTERVAL_MS=300000
# Webhook mode is disabled in the local prototype. Re-enable later for deployed HTTPS.
# CALENDAR_WEBHOOK_URL=
# CALENDAR_WEBHOOK_TOKEN=
# CALENDAR_WATCH_TTL_SECONDS=604800
SLACK_SEARCH_LOOKBACK_DAYS=30
SENTRY_PROJECT=
POSTHOG_API_KEY=phx_...
POSTHOG_PROJECT_ID=

# ────────────────────────────────────────────────────────────
# Managed services
# ────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
BRAINTRUST_API_KEY=

# ────────────────────────────────────────────────────────────
# App
# ────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
AGENT_RUNTIME_URL=http://localhost:4000
CONNECTOR_WATCH_ENABLED=false
CONNECTOR_WATCH_PROVIDERS=gmail,calendar,slack,github,linear,sentry
CONNECTOR_WATCH_INTERVAL_MS=300000

# User-authorized connection center OAuth apps.
# Register callback URLs as:
#   http://localhost:3000/api/connections/oauth/<provider>/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
SENTRY_CLIENT_ID=
SENTRY_CLIENT_SECRET=

# MCP servers (each runs as its own process — see packages/mcp-servers/*)
MCP_SLACK_URL=http://127.0.0.1:4110/slack/mcp
MCP_GITHUB_URL=http://127.0.0.1:4110/github/mcp
MCP_LINEAR_URL=http://127.0.0.1:4110/linear/mcp
MCP_SENTRY_URL=http://127.0.0.1:4110/sentry/mcp
MCP_GMAIL_URL=http://127.0.0.1:4110/gmail/mcp

API_SECRET_KEY=hermes-dev-secret-change-in-prod
MCP_GATEWAY_SECRET=hermes-dev-secret-change-in-prod
