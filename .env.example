# ────────────────────────────────────────────────────────────
# LLM Providers
# ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ────────────────────────────────────────────────────────────
# Infrastructure (cloud-first — same connection shape dev & prod)
# ────────────────────────────────────────────────────────────
# Neon PostgreSQL (dev branch). Includes pgvector extension.
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/hermes?sslmode=require

# Upstash Redis. TLS (rediss://).
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379
# Upstash HTTP (for edge/Next.js). Optional if only ioredis is used.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ────────────────────────────────────────────────────────────
# MCP Integrations (populated in Phase 3)
# ────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
SLACK_BOT_TOKEN=xoxb-...
# Gmail — OAuth2. Run `pnpm gmail:auth` once to mint GOOGLE_REFRESH_TOKEN.
# Google Cloud project → enable Gmail API → Desktop-app OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
LINEAR_API_KEY=lin_api_...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=
SENTRY_PROJECT=
POSTHOG_API_KEY=phx_...
POSTHOG_PROJECT_ID=

# ────────────────────────────────────────────────────────────
# Managed services
# ────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
BRAINTRUST_API_KEY=

# ────────────────────────────────────────────────────────────
# App
# ────────────────────────────────────────────────────────────
AGENT_RUNTIME_URL=http://localhost:4000

# MCP servers (each runs as its own process — see packages/mcp-servers/*)
MCP_SLACK_URL=http://127.0.0.1:4100/mcp
MCP_GITHUB_URL=http://127.0.0.1:4101/mcp
MCP_LINEAR_URL=http://127.0.0.1:4102/mcp
MCP_SENTRY_URL=http://127.0.0.1:4103/mcp
MCP_GMAIL_URL=http://127.0.0.1:4104/mcp

API_SECRET_KEY=hermes-dev-secret-change-in-prod
