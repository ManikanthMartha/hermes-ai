# ────────────────────────────────────────────────────────────
# LLM Providers
# ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ────────────────────────────────────────────────────────────
# Infrastructure (cloud-first — same connection shape dev & prod)
# ────────────────────────────────────────────────────────────
# Neon PostgreSQL (dev branch). Includes pgvector extension.
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/hermes?sslmode=require

# Upstash Redis. TLS (rediss://).
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379
# Upstash HTTP (for edge/Next.js). Optional if only ioredis is used.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ────────────────────────────────────────────────────────────
# MCP Integrations (populated in Phase 3)
# ────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
SLACK_BOT_TOKEN=xoxb-...
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINEAR_API_KEY=lin_api_...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=
SENTRY_PROJECT=
POSTHOG_API_KEY=phx_...
POSTHOG_PROJECT_ID=

# ────────────────────────────────────────────────────────────
# Managed services
# ────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
BRAINTRUST_API_KEY=

# ────────────────────────────────────────────────────────────
# App
# ────────────────────────────────────────────────────────────
AGENT_RUNTIME_URL=http://localhost:4000
NEXT_PUBLIC_AGENT_RUNTIME_URL=http://localhost:4000
API_SECRET_KEY=hermes-dev-secret-change-in-prod
